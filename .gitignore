# Secrets — реальные креды прод-БД SCADA, НИКОГДА не публиковать
.env
.env.local
.env.*.local
# .env.example содержит реальные прод-креды (не плейсхолдеры) → тоже не коммитим
.env.example
.env.*.example

# Python virtualenv и кэши (переустанавливаемое, платформозависимое)
venv/
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Node зависимости (переустанавливаются из package.json)
node_modules/
frontend/node_modules/

# ML-модели — не грузим (1.5 ГБ бинарников, по запросу пользователя)
backend/models/

# Git
.git/

# Скретч оркестратора OMC (research/state/logs) — содержит прод-пароль и не является кодом
.omc/

# Скретч инструментов и локальные настройки — не код
.playwright-mcp/
.superpowers/
.claude/

# Артефакты обучения / рантайма / логи — переустанавливаемое, не код
catboost_info/
backend/logs/
*.log
backend/live_state.json
backend/state/*.json

# Крупные данные и дампы (не в VCS — раздувают .git)
Рисёрч/
backend/_db_backup*/
backend/_archive/
*.csv
*.tar.gz
