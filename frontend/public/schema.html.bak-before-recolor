   if(sev==='crit'||sev===2)crit++;else if(sev==='warn'||sev===1)warn++;});
  if(crit>0||warn>0){
   const x=+r.getAttribute('x'),y=+r.getAttribute('y'),w=+r.getAttribute('width');
   const cx=x+w-14,cy=y+14;
   const col=crit>0?'#c4321f':'#e8890c',n=crit>0?crit:warn;
