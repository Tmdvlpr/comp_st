--bg:#0d1426;--panel2:rgba(26,31,56,0.78);--surf2:rgba(38,44,74,0.82);--line:rgba(132,140,200,0.16);--line2:rgba(132,140,200,0.30);--ink:#E6ECF6;--mut:#9BA5BC;--amber:#58A6FF;--vec:#3FB8AF;--sheet:#fcfcfa;
