/* ---- отрисовка маркеров на активном листе ---- */
function injectSensors(){
 const svg=wrap.querySelector('svg');if(!svg)return;
 let g='';
 SENS.forEach((s,i)=>{
  if(s[7]!==cur)return;
  const[short,,,,kind,layer,norm,,x,y]=s;
  const col=SENS_COL[kind];
  const w=Math.max(58,short.length*7.5+20);
  g+=`<g class="hot sens l-${layer}" data-key="sn_${i}">`
   +`<rect x="${x-12}" y="${y-12}" width="${w}" height="36" rx="11" fill="#fff" fill-opacity="0.92" stroke="${col}" stroke-width="1.8"/>`
   +`<circle cx="${x}" cy="${y}" r="8.5" fill="${col}"/>`
   +`<text x="${x}" y="${y+0.5}" font-family="Inter,Arial,sans-serif" font-size="9" font-weight="700" text-anchor="middle" fill="#fff" dominant-baseline="middle">${kind}</text>`
   +`<text x="${x+13}" y="${y-1}" font-family="Inter,Arial,sans-serif" font-size="9.5" font-weight="700" text-anchor="start" fill="${col}" dominant-baseline="middle">${short}</text>`
   +`<text x="${x-7}" y="${y+15}" font-family="Inter,Arial,sans-serif" font-size="8" font-weight="400" text-anchor="start" fill="#444c57" dominant-baseline="middle">${norm.split("(")[0].slice(0,18)}</text>`
   +`<rect x="${x-12}" y="${y-12}" width="${w}" height="36" fill="#fff" fill-opacity="0.001" class="hit"/>`
   +`<rect x="${x-12}" y="${y-12}" width="${w}" height="36" rx="11" fill="none" stroke="#ff8c1a" stroke-width="3" class="hl" style="opacity:0"/></g>`;
 });
 if(g){const grp=document.createElementNS('http://www.w3.org/2000/svg','g');
  grp.setAttribute('class','sensors');grp.innerHTML=g;svg.appendChild(grp);}
}
