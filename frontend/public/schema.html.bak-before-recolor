   c.setAttribute('class','sevdot');c.setAttribute('cx',cx);c.setAttribute('cy',cy);
   c.setAttribute('r','7');c.setAttribute('fill',col);
   c.setAttribute('stroke','#fff');c.setAttribute('stroke-width','1.5');
   const tx=document.createElementNS(SVGNS,'text');
   tx.setAttribute('class','sevdot');tx.setAttribute('x',cx);tx.setAttribute('y',cy);
   tx.setAttribute('font-family','Inter,Arial,sans-serif');tx.setAttribute('font-size','10');
   tx.setAttribute('font-weight','700');tx.setAttribute('text-anchor','middle');
   tx.setAttribute('dominant-baseline','central');tx.setAttribute('fill','#fff');
   tx.textContent=String(n);
   /* список конкретных датчиков ГПА в тревоге — для тултипа и перехода по клику */
   const _list=[],_seen={};
   SENS.forEach((ss,si)=>{ if(ss[7]!=='gpa')return;
    const tg=ss[3].replace(/GPA-1/g,'GPA-'+g).replace(/GT-1/g,'GT-'+g);
    const sv=PVDATA_SEV[tg];
    if((sv==='crit'||sv===2||sv==='warn'||sv===1)&&!_seen[ss[0]]){_seen[ss[0]]=1;
     _list.push({i:si,short:ss[0],desc:ss[2],crit:(sv==='crit'||sv===2)});}});
   _list.sort((p,q)=>(q.crit?1:0)-(p.crit?1:0));
   [c,tx].forEach(el=>{
    el.style.cursor='pointer'; el.style.pointerEvents='all';
    el.addEventListener('pointerdown',ev=>ev.stopPropagation());
    el.addEventListener('mouseenter',ev=>{
     let h=`<h4>ГПА-${g}00 — отклонения</h4><div class="c">${crit} крит · ${warn} предупр.</div><table>`;
     _list.forEach(o=>{h+=`<tr><td style="color:${o.crit?'#EF4444':'#F59E0B'};font-weight:700;white-space:nowrap">${o.short}</td><td>${o.desc}</td></tr>`;});
     h+=`</table><div class="more">клик — перейти к датчику на схеме</div>`;
     showTip(h,ev.clientX,ev.clientY);});
    el.addEventListener('mouseleave',hideTip);
    el.addEventListener('click',ev=>{ev.stopPropagation();hideTip();if(_list.length){const _s=SENS[_list[0].i];goMonitor(_s[3].replace(/GPA-1/g,'GPA-'+g).replace(/GT-1/g,'GT-'+g));}});});
   grp.appendChild(c);grp.appendChild(tx);}}}
