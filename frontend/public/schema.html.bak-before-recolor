const LAYER_STATE={gas:false,mech:false,leak:false,state:false};
function buildLayerButtons(){
 const bar=document.querySelector('.bar');const sp=bar.querySelector('.spacer');
 const lbl=document.createElement('span');lbl.className='hint';lbl.textContent='Слои:';bar.insertBefore(lbl,sp);
 Object.entries(SENS_LAYERS).forEach(([k,nm])=>{
  const b=document.createElement('button');b.className='b lay';b.dataset.layer=k;b.textContent=nm;
  b.onclick=()=>{LAYER_STATE[k]=!LAYER_STATE[k];b.classList.toggle('on',LAYER_STATE[k]);applyLayers()};
  bar.insertBefore(b,sp);});
}
function applyLayers(){
 wrap.querySelectorAll('.sens').forEach(el=>{
  const on=Object.keys(LAYER_STATE).some(k=>LAYER_STATE[k]&&el.classList.contains('l-'+k));
  el.style.display=on?'':'none';});
